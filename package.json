      <Navbar/>
      <h1 style={{textAlign:'center',margin:'20px'}}>Available Cars</h1>
      <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(250px,1fr))',gap:'20px',padding:'20px'}}>
        {cars.map(car => <CarCard key={car.id} car={car}/>)}
      </div>
    </div>
  )
